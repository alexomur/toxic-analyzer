{
  "name": "@toxic-analyzer/discord-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot client for the Toxic Analyzer backend API.",
  "type": "module",
  "packageManager": "npm@11.2.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
